# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=energy_mountain

# Redis配置（可选，验证码依赖 Redis）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置（生产环境务必更换 JWT_SECRET）
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=24h

# MongoDB（对战详细日志，用于对战记录展示）
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=energy_mountain

# 服务器配置
PORT=3000
CORS_ORIGIN=*

# MiniMAX API配置（OpenAI API 兼容模式）
# 获取API密钥：访问 https://platform.minimaxi.com/user-center/basic-information/interface-key
# 创建 "Coding Plan Key"（仅文本模型）或 "Pay-as-you-go secret key"（所有模态，推荐）
# 注意：多模态功能（图像、视频、语音）需要 "Pay-as-you-go secret key"
MINIMAX_API_KEY=your_minimax_api_key
# OpenAI API 兼容模式端点
# 中国区：https://api.minimaxi.com/v1/chat/completions（推荐）
# 国际区：https://api.minimax.io/v1/chat/completions
# 支持的模型：MiniMax-M2.5、MiniMax-M2.5-highspeed、MiniMax-M2.1、MiniMax-M2.1-highspeed、MiniMax-M2
MINIMAX_API_URL=https://api.minimaxi.com/v1/chat/completions
# 每次AI对话消耗的能量值
AI_AGENT_ENERGY_COST=5

# MiniMAX 多模态 API 配置（可选）
# 图像生成模型：image-01, image-01-live
# DEFAULT_IMAGE_MODEL=image-01
# 视频生成模型：MiniMax-Hailuo-2.3, MiniMax-Hailuo-02, T2V-01-Director, T2V-01
# DEFAULT_VIDEO_MODEL=MiniMax-Hailuo-2.3
# 语音合成模型：speech-2.8-hd, speech-2.8-turbo, speech-2.6-hd, speech-2.6-turbo, speech-02-hd, speech-02-turbo
# DEFAULT_T2A_MODEL=speech-2.8-hd

# 阿里云百炼（DashScope）API（当 ai_provider=bailian 时使用）
# 可在管理后台「游戏配置」中填写，或在此设置；获取：https://bailian.console.aliyun.com/ → 密钥管理
# DASHSCOPE_API_KEY=your_dashscope_api_key
